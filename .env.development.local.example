# ------- Tolgee (optional) -------
# Get these from your Tolgee project settings. Bundled JSON translations in
# messages/ work without any of them.
NEXT_PUBLIC_TOLGEE_API_KEY=your_key_here
NEXT_PUBLIC_TOLGEE_API_URL=https://app.tolgee.io
NEXT_PUBLIC_TOLGEE_CDN_URL=https://cdn.tolg.ee/your_cdn_id

# ------- API -------
# Base URL of the giftmeBE backend (local dev shown; use your deployed API in prod).
NEXT_PUBLIC_API_URL=https://giftmebe.onrender.com/api

# Set to "true" to run the UI on in-memory mock data with no backend.
# Anything else (or unset) uses the real API. Never enable in production.
NEXT_PUBLIC_USE_MOCKS=false
